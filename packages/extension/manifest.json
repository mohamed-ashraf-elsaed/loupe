{
  "manifest_version": 3,
  "name": "Loupe \u2014 visual feedback",
  "version": "0.7.0",
  "description": "Inspect any page, pin comments to elements, and hand them to Claude \u2014 no SDK install required.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Loupe",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  }
}
