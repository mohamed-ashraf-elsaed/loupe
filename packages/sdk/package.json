{
  "name": "@loupe/sdk",
  "version": "0.1.0",
  "description": "Embeddable visual-feedback layer: pin comments to the live UI and hand them to Claude.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["feedback", "annotation", "visual-feedback", "product-management", "claude", "mcp"],
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/mohamed-ashraf-elsaed/loupe.git", "directory": "packages/sdk" },
  "homepage": "https://mohamed-ashraf-elsaed.github.io/loupe/",
  "publishConfig": { "access": "public" },
  "devDependencies": {
    "@loupe/shared": "*",
    "modern-screenshot": "^4.6.6"
  }
}
